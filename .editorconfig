# EditorConfig is awesome: https://EditorConfig.org

root = true

# Java files
[*.java]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
max_line_length = 200
trim_trailing_whitespace = true
insert_final_newline = true

# XML files (pom.xml, web.xml, etc.)
[*.xml]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# YAML files
[*.{yaml,yml}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown files
[*.md]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
insert_final_newline = true

# Properties files
[*.properties]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# Shell scripts
[*.sh]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
